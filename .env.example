# Server-only values. Put these in Vercel Project Settings > Environment Variables.
OPENAI_API_KEY=
NEIS_API_KEY=
KKOKKOMU_ADMIN_EMAILS=
KKOKKOMU_ALLOWED_ORIGINS=

# Firebase Admin for Vercel serverless API.
# Use either FIREBASE_SERVICE_ACCOUNT or the split client email/private key pair.
FIREBASE_PROJECT_ID=kkokkomu-d6a4c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT=

# LM Studio remote provider. Required for the admin "local LLM" option to work in production.
LMSTUDIO_API_KEY=
LMSTUDIO_API_URL=
LMSTUDIO_GEMMA_12B_MODEL=
LMSTUDIO_GEMMA_26B_MODEL=
LMSTUDIO_GEMMA_E2B_MODEL=
LMSTUDIO_GEMMA_E4B_MODEL=

# Browser-safe Firebase Web SDK config.
VITE_FIREBASE_AUTH_ENABLED=true
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=kkokkomu-d6a4c
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Local Vercel CLI control values. Do not sync these into Vercel project env.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
